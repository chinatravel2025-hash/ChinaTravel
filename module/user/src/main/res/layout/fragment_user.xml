<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.travel.user.UserViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@mipmap/user_top_bg"
            app:layout_constraintTop_toTopOf="parent" />
        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/iv_head"
            android:layout_width="@dimen/dp_60"
            android:layout_height="@dimen/dp_60"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginTop="@dimen/dp_98"
            android:src="@drawable/user_home_top_bg"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:riv_corner_radius="@dimen/dp_8" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:textColor="@color/c_333333"
            android:textSize="@dimen/sp_22"
            android:textStyle="bold"
            android:text="@{vm.userInfo.user_name}"
            app:layout_constraintLeft_toRightOf="@id/iv_head"
            app:layout_constraintTop_toTopOf="@id/iv_head"
            tools:text="Mickey Halloween" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_marginTop="@dimen/dp_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:textColor="@color/txt_999999"
            android:textSize="@dimen/sp_14"
            android:text="@{vm.userInfo.mail}"
            app:layout_constraintLeft_toRightOf="@id/iv_head"
            app:layout_constraintTop_toBottomOf="@id/tv_name"
            tools:text="shanghai halloween@qq.com" />
            <View
                android:id="@+id/view_line"
                android:layout_marginTop="@dimen/dp_50"
                app:layout_constraintTop_toBottomOf="@id/iv_head"
                android:background="@color/bg_FFF5F5F5"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_10"/>
        <LinearLayout
            app:layout_constraintTop_toBottomOf="@id/view_line"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:onClick="@{()->vm.navigationOrders()}"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_orders"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"/>
                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_12"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Orders"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:visibility="gone"
                android:layout_marginStart="@dimen/dp_50"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>
            <LinearLayout
                android:visibility="gone"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_my_trips"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"/>
                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_12"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="My Trips"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_50"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>
            <LinearLayout
                android:onClick="@{()->vm.navigationFavorite()}"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_favorite"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"/>
                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_12"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Favorite"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_50"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>
            <LinearLayout
                android:onClick="@{()->vm.navigationPreferences()}"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_preferences"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"/>
                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_12"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Preferences"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_50"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>
            <LinearLayout
                android:onClick="@{()->vm.navigationSupport()}"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_support"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"/>
                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_12"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Support"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_50"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>
            <LinearLayout
                android:onClick="@{()->vm.showPrivacyPolicy()}"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_preferences"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"/>
                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_12"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Privacy Policy"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_50"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>

        </LinearLayout>

        <TextView
            android:onClick="@{()->vm.logOut()}"
            android:layout_marginHorizontal="@dimen/dp_30"
            android:layout_marginBottom="@dimen/dp_100"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@drawable/shape_r28_b_ff12c286"
            android:text="Sign out"
            android:gravity="center"
            android:textColor="@color/c_333333"
            android:textStyle="bold"
            android:textSize="@dimen/sp_18"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_56"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
    