<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />


        <variable
            name="ac"
            type="com.travel.user.ui.preferences.UserPreferencesActivity" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
      >

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@mipmap/user_top_bg"
            app:layout_constraintTop_toTopOf="parent" />
        <com.example.base.view.StatusBarHolderView
            android:id="@+id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_top"
            app:layout_constraintTop_toBottomOf="@id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:padding="@dimen/dp_10"
                android:src="@mipmap/ic_black_top_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                />
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preferences_title"
                android:textColor="@color/c_333333"
                android:textSize="@dimen/sp_24"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:background="@color/white"
            android:layout_marginTop="@dimen/dp_100"
        app:layout_constraintTop_toTopOf="parent"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">

                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_30"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Notification"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw"
                    android:layout_width="@dimen/dp_60"
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:maxWidth="@dimen/dp_100"
                    android:thumb="@drawable/switch_thumb_selector"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:track="@drawable/switch_track_black_selector" />

            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_30"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>
            <LinearLayout
                android:onClick="@{()->ac.navigationPreferences()}"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">

                <TextView
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dp_30"
                    android:textSize="@dimen/sp_19"
                    android:textColor="@color/c_333333"
                    android:text="Close account"
                    android:layout_weight="1"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:layout_marginEnd="@dimen/dp_16"
                    android:layout_gravity="center_vertical"
                    android:src="@mipmap/user_home_arrow_more"
                    android:layout_width="@dimen/dp_15"
                    android:layout_height="@dimen/dp_15"/>
            </LinearLayout>
            <View
                android:layout_marginStart="@dimen/dp_30"
                android:background="@color/bg_12C286"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"/>



        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>