<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.travel.home.HomeViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_bg_F3FFF8">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            app:layout_constraintTop_toTopOf="parent" />

        <com.example.base.view.StatusBarHolderView
            android:id="@+id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />


        <LinearLayout
            android:visibility="gone"
            android:id="@+id/ll_search"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:layout_marginHorizontal="@dimen/dp_12"
            android:layout_marginTop="@dimen/dp_10"
            android:background="@drawable/shape_r8_fff"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/view_holder">

            <ImageView
                android:layout_width="@dimen/dp_30"
                android:layout_height="@dimen/dp_30"
                android:layout_marginStart="@dimen/dp_5"
                android:src="@mipmap/ic_home_search" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_5"
                android:text="@string/home_search_where_to"
                android:textColor="@color/text_FF999999"
                android:textSize="@dimen/sp_17" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nest_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_20"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_search">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingTop="@dimen/dp_16"
                android:paddingBottom="@dimen/dp_30">

                <FrameLayout
                    android:id="@+id/fl_banner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_80"
                    android:layout_marginHorizontal="@dimen/dp_12"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.youth.banner.Banner
                        android:id="@+id/banner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:banner_indicator_normal_color="@color/bg_FFD9D9D9"
                        app:banner_indicator_selected_color="@color/bg_7DAAB0"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.youth.banner.indicator.RectangleIndicator
                        android:id="@+id/circle_indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="@dimen/dp_4"
                        app:layout_constraintBottom_toBottomOf="@id/banner" />
                </FrameLayout>
                <!--city-->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cons_container_city"
                    app:layout_constraintTop_toBottomOf="@id/fl_banner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_15">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dp_12"
                        android:text="Teending cities you can’t miss"
                        android:textColor="@color/c_333333"
                        android:textSize="@dimen/sp_19"
                        android:textStyle="bold"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_5"
                        android:background="@drawable/shape_r3_9912c286"
                        android:translationY="@dimen/dp_m_2"
                        app:layout_constraintBottom_toBottomOf="@id/tv_title"
                        app:layout_constraintLeft_toLeftOf="@id/tv_title"
                        app:layout_constraintRight_toRightOf="@id/tv_title" />



                    <FrameLayout
                        app:layout_constraintTop_toBottomOf="@id/tv_title"
                        android:layout_marginTop="@dimen/dp_12"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_190">
                        <com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal
                            android:id="@+id/refreshLayout_city"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:srlEnablePreviewInEditMode="true"
                            app:srlEnableFooterTranslationContent="true"
                            app:srlEnableHeaderTranslationContent="true"
                            >
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_city"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dp_190"
                                android:overScrollMode="never"
                                android:orientation="horizontal"
                                tools:listitem="@layout/item_home_city_list"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                />

                        </com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal>

                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cons_container_day_trip"
                    app:layout_constraintTop_toBottomOf="@id/cons_container_city"
                    android:layout_marginTop="@dimen/dp_22"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_marginStart="@dimen/dp_12"
                        app:layout_constraintLeft_toLeftOf="parent"
                        android:id="@+id/tv_day_title"
                        app:layout_constraintTop_toTopOf="parent"
                        android:textColor="@color/c_333333"
                        android:textStyle="bold"
                        android:textSize="@dimen/sp_19"
                        android:text="Day trips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <View
                        android:translationY="@dimen/dp_m_2"
                        app:layout_constraintBottom_toBottomOf="@id/tv_day_title"
                        app:layout_constraintRight_toRightOf="@id/tv_day_title"
                        app:layout_constraintLeft_toLeftOf="@id/tv_day_title"
                        android:background="@drawable/shape_r3_9912c286"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_5"/>
                    <FrameLayout
                        app:layout_constraintTop_toBottomOf="@id/tv_day_title"
                        android:layout_marginTop="@dimen/dp_12"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_124">
                        <com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal
                            android:id="@+id/refreshLayout_day"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:srlEnablePreviewInEditMode="true"
                            app:srlEnableFooterTranslationContent="true"
                            app:srlEnableHeaderTranslationContent="true">
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_trip"
                                android:orientation="horizontal"
                                android:overScrollMode="never"
                                tools:listitem="@layout/item_home_day_trip_list"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dp_124"/>
                        </com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal>

                    </FrameLayout>




                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cons_container_thing"
                    app:layout_constraintTop_toBottomOf="@id/cons_container_day_trip"
                    android:layout_marginTop="@dimen/dp_22"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_things_title"
                        android:layout_marginStart="@dimen/dp_12"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:textColor="@color/c_333333"
                        android:textStyle="bold"
                        android:textSize="@dimen/sp_19"
                        android:text="Things to do"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <View
                        android:translationY="@dimen/dp_m_2"
                        app:layout_constraintBottom_toBottomOf="@id/tv_things_title"
                        app:layout_constraintRight_toRightOf="@id/tv_things_title"
                        app:layout_constraintLeft_toLeftOf="@id/tv_things_title"
                        android:background="@drawable/shape_r3_9912c286"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_5"/>

                    <FrameLayout
                        app:layout_constraintTop_toBottomOf="@id/tv_things_title"
                        android:layout_marginTop="@dimen/dp_12"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_165">
                        <com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal
                            android:id="@+id/refreshLayout_thing"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:srlEnablePreviewInEditMode="true"
                            app:srlEnableFooterTranslationContent="true"
                            app:srlEnableHeaderTranslationContent="true">
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_things"
                                android:orientation="horizontal"
                                android:overScrollMode="never"
                                tools:listitem="@layout/item_home_things_list"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dp_165"/>
                        </com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal>

                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:onClick="@{()->vm.myTrip()}"
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_56"
                    android:layout_marginHorizontal="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_24"
                    android:background="@drawable/shape_r100_ff12c286"
                    android:gravity="center"
                    android:text="Tailor my trip"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/cons_container_thing" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>