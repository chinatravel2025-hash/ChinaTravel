<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/color_bg_F3FFF8"
        android:layout_width="match_parent"  
        android:layout_height="match_parent">
        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <com.example.base.view.StatusBarHolderView
                android:id="@+id/view_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:padding="@dimen/dp_10"
                android:src="@mipmap/ic_black_top_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_holder" />

            <TextView
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorite"
                android:textColor="@color/c_333333"
                android:textSize="@dimen/sp_24"
                app:layout_constraintBottom_toBottomOf="@id/iv_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_back" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_marginTop="@dimen/dp_15"
            app:layout_constraintTop_toBottomOf="@id/cons_top"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="0dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="@dimen/dp_20"
                android:id="@+id/cons_container_city"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
               >

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:text="City"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_title"
                    app:layout_constraintLeft_toLeftOf="@id/tv_title"
                    app:layout_constraintRight_toRightOf="@id/tv_title" />



                <FrameLayout
                    app:layout_constraintTop_toBottomOf="@id/tv_title"
                    android:layout_marginTop="@dimen/dp_12"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_190">
                    <com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal
                        android:id="@+id/refreshLayout_city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:srlEnablePreviewInEditMode="true"
                        app:srlEnableFooterTranslationContent="true"
                        app:srlEnableHeaderTranslationContent="true"
                        >
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_city"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_190"
                            android:overScrollMode="never"
                            android:orientation="horizontal"
                            tools:listitem="@layout/item_home_city_list"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            />

                    </com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal>

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cons_container_day_trip"
                app:layout_constraintTop_toBottomOf="@id/cons_container_city"
                android:layout_marginTop="@dimen/dp_22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    app:layout_constraintLeft_toLeftOf="parent"
                    android:id="@+id/tv_day_title"
                    app:layout_constraintTop_toTopOf="parent"
                    android:textColor="@color/c_333333"
                    android:textStyle="bold"
                    android:textSize="@dimen/sp_19"
                    android:text="Trip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <View
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_day_title"
                    app:layout_constraintRight_toRightOf="@id/tv_day_title"
                    app:layout_constraintLeft_toLeftOf="@id/tv_day_title"
                    android:background="@drawable/shape_r3_9912c286"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"/>
                <FrameLayout
                    app:layout_constraintTop_toBottomOf="@id/tv_day_title"
                    android:layout_marginTop="@dimen/dp_12"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_124">
                    <com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal
                        android:id="@+id/refreshLayout_day"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:srlEnablePreviewInEditMode="true"
                        app:srlEnableFooterTranslationContent="true"
                        app:srlEnableHeaderTranslationContent="true">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_trip"
                            android:orientation="horizontal"
                            android:overScrollMode="never"
                            tools:listitem="@layout/item_home_day_trip_list"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_124"/>
                    </com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal>

                </FrameLayout>




            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cons_container_thing"
                app:layout_constraintTop_toBottomOf="@id/cons_container_day_trip"
                android:layout_marginTop="@dimen/dp_22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_things_title"
                    android:layout_marginStart="@dimen/dp_12"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:textColor="@color/c_333333"
                    android:textStyle="bold"
                    android:textSize="@dimen/sp_19"
                    android:text="Things to do"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <View
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_things_title"
                    app:layout_constraintRight_toRightOf="@id/tv_things_title"
                    app:layout_constraintLeft_toLeftOf="@id/tv_things_title"
                    android:background="@drawable/shape_r3_9912c286"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"/>

                <FrameLayout
                    app:layout_constraintTop_toBottomOf="@id/tv_things_title"
                    android:layout_marginTop="@dimen/dp_12"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_165">
                    <com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal
                        android:id="@+id/refreshLayout_thing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:srlEnablePreviewInEditMode="true"
                        app:srlEnableFooterTranslationContent="true"
                        app:srlEnableHeaderTranslationContent="true">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_things"
                            android:orientation="horizontal"
                            android:overScrollMode="never"
                            tools:listitem="@layout/item_home_things_list"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_165"/>
                    </com.scwang.smartrefresh.horizontal.SmartRefreshHorizontal>

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>