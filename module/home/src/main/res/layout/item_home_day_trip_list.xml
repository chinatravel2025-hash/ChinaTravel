<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.aws.bean.entities.home.TravelProductItem" />

        <import type="com.example.base.utils.CommonNumber" />

        <variable
            name="position"
            type="java.lang.Integer" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="@dimen/dp_266"
        android:layout_height="@dimen/dp_124"
        android:layout_marginStart="@dimen/dp_12"
        android:background="@drawable/shape_radius_dp8_e8e5e0">

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/iv_cover"
            urlList="@{vm.pic_url_list}"
            android:layout_width="@dimen/dp_124"
            android:layout_height="@dimen/dp_124"
            android:scaleType="centerCrop"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:riv_corner_radius="@dimen/dp_8" />

        <ImageView
            android:layout_width="@dimen/dp_38"
            android:layout_height="@dimen/dp_19"
            android:src="@mipmap/ic_home_hot_tag"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_like"
            visibleWhen="@{vm.is_like==1}"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:padding="@dimen/dp_8"
            android:src="@mipmap/home_like_ck"
            app:layout_constraintRight_toRightOf="@id/iv_cover"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_unlike"
            visibleWhen="@{vm.is_like==0}"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:padding="@dimen/dp_8"
            android:src="@mipmap/home_like_unck"
            app:layout_constraintRight_toRightOf="@id/iv_cover"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_9"
            android:layout_marginTop="@dimen/dp_9"
            android:text="@{vm.title}"
            android:textColor="@color/c_333333"
            android:textSize="@dimen/sp_13"
            app:layout_constraintLeft_toRightOf="@id/iv_cover"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/ll_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_9"
            android:layout_marginTop="@dimen/dp_2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintLeft_toRightOf="@id/iv_cover"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <com.china.travel.widget.widget.RatingBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:starCount="5"
                app:starEmpty="@mipmap/ic_hot_off"
                app:starFill="@mipmap/ic_hot_on"
                app:starHalf="@mipmap/ic_hot_half"
                app:starImageSize="@dimen/dp_8"
                app:starPadding="@dimen/dp_5"
                android:id="@+id/rating" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{vm.hotLevel}"
                android:textColor="@color/txt_FF6C6C"
                android:textSize="@dimen/sp_11"
                tools:text="4.9" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/dp_2"
            android:layout_marginStart="@dimen/dp_9"
            android:layout_marginTop="@dimen/dp_4"
            android:ellipsize="end"
            android:lines="4"
            android:text="@{vm.about}"
            android:textColor="@color/txt_FF666666"
            android:textSize="@dimen/sp_11"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/iv_cover"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_start" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>