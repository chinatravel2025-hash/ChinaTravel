<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

        <variable
            name="vm"
            type="com.aws.bean.entities.home.TravelProductItem" />

        <import type="com.example.base.utils.CommonNumber" />
        <variable
            name="position"
            type="java.lang.Integer" />
    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_marginStart="@dimen/dp_12"
        android:layout_width="@dimen/dp_140"
        android:layout_height="@dimen/dp_140">

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/iv_bg"
            app:riv_corner_radius="@dimen/dp_8"
            urlList="@{vm.pic_url_list}"
            android:scaleType="centerCrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ImageView
            visibleWhen="@{vm.is_like==1}"
            android:id="@+id/iv_like"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/dp_5"
            app:layout_constraintRight_toRightOf="parent"
            android:src="@mipmap/home_like_ck"
            android:padding="@dimen/dp_8"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"/>
        <ImageView
            visibleWhen="@{vm.is_like!=1}"
            android:id="@+id/iv_unlike"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/dp_5"
            app:layout_constraintRight_toRightOf="parent"
            android:src="@mipmap/home_like_unck"
            android:padding="@dimen/dp_8"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"/>

        <TextView
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="@dimen/dp_12"
            android:layout_marginBottom="@dimen/dp_12"
            android:text="@{vm.title}"
            android:textSize="@dimen/sp_22"
            android:textColor="@color/black"
            android:layout_width="0dp"
            android:singleLine="true"
            android:ellipsize="end"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_height="wrap_content"/>
        
    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>