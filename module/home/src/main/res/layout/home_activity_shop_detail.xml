<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_bg_F3FFF8">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <com.example.base.view.StatusBarHolderView
                android:id="@+id/view_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:padding="@dimen/dp_10"
                android:src="@mipmap/ic_black_top_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_holder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restaurant"
                android:textStyle="bold"
                android:textColor="@color/c_333333"
                android:textSize="@dimen/sp_24"
                app:layout_constraintBottom_toBottomOf="@id/iv_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_back" />
        </androidx.constraintlayout.widget.ConstraintLayout>



        <androidx.core.widget.NestedScrollView
            android:layout_marginTop="@dimen/dp_8"
            android:id="@+id/nest_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cons_top">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:paddingBottom="@dimen/dp_30"
                android:paddingTop="@dimen/dp_16"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="@dimen/dp_12"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/fl_banner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_215"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.youth.banner.Banner
                        android:transitionName="share_shop"
                        android:id="@+id/banner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:banner_indicator_normal_color="@color/bg_FFD9D9D9"
                        app:banner_indicator_selected_color="@color/bg_7DAAB0"
                        app:layout_constraintTop_toTopOf="parent" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_city_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_17"
                    android:text="Shanghai Restaurant"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/fl_banner" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_city_name"
                    app:layout_constraintLeft_toLeftOf="@id/tv_city_name"
                    app:layout_constraintRight_toRightOf="@id/tv_city_name" />
                <Space
                    android:id="@+id/holder"
                    app:layout_constraintTop_toBottomOf="@id/tv_city_name"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_220"/>
                <TextView
                    android:id="@+id/tv_about"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_16"
                    android:text="About"
                    android:textStyle="bold"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_15"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/holder" />

                <TextView
                    android:id="@+id/tv_about_content"
                    android:layout_width="0dp"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_5"
                    android:lineHeight="@dimen/dp_15"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_12"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_about" />

                <TextView
                    android:id="@+id/tv_day_trip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_25"
                    android:text="Explore the area"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_about_content" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_day_trip"
                    app:layout_constraintLeft_toLeftOf="@id/tv_day_trip"
                    app:layout_constraintRight_toRightOf="@id/tv_day_trip" />

                <View
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintTop_toBottomOf="@id/tv_day_trip"
                    android:id="@+id/space"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_110"/>




                <TextView
                    android:id="@+id/tv_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_16"
                    android:text="Address"
                    android:textStyle="bold"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_15"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/space" />

                <TextView
                    android:id="@+id/tv_about_address"
                    android:layout_width="0dp"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_5"
                    android:lineHeight="@dimen/dp_15"
                    android:text="Century Avenue, Pudong, Shanghai"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_12"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_address" />


                <TextView
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_56"
                    android:layout_marginHorizontal="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_30"
                    android:background="@drawable/shape_r100_ff12c286"
                    android:gravity="center"
                    android:text="Tailor my trip"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tv_about_address" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>