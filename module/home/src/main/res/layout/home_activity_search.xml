<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/color_bg_F3FFF8"
        android:layout_width="match_parent"  
        android:layout_height="match_parent">
        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <com.example.base.view.StatusBarHolderView
            android:id="@+id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_marginTop="@dimen/dp_10"
            android:id="@+id/ll_search"
            android:layout_marginHorizontal="@dimen/dp_12"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/shape_r8_fff"
            app:layout_constraintTop_toBottomOf="@id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50">
            <ImageView
                android:layout_marginStart="@dimen/dp_5"
                android:src="@mipmap/ic_home_search"
                android:layout_width="@dimen/dp_30"
                android:layout_height="@dimen/dp_30"/>

            <androidx.appcompat.widget.AppCompatEditText
                android:textCursorDrawable="@drawable/shape_cursor"
                android:id="@+id/ed_email"
                android:textSize="@dimen/sp_17"
                android:layout_marginStart="@dimen/dp_5"
                android:hint="@string/home_search_where_to"
                android:gravity="center_vertical"
                android:textColor="@color/c_333333"
                android:textColorHint="@color/text_FF999999"
                android:singleLine="true"
                android:background="@color/transparent"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_48"/>
            <ImageView
                android:layout_marginEnd="@dimen/dp_8"
                android:src="@mipmap/x_20_close"
                android:padding="@dimen/dp_8"
                android:layout_width="@dimen/dp_36"
                android:layout_height="@dimen/dp_36"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
           app:layout_constraintTop_toBottomOf="@id/ll_search"
            android:layout_marginTop="@dimen/dp_16"
            android:id="@+id/rv_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
        />
        <!--empty show-->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            app:layout_constraintTop_toBottomOf="@id/ll_search"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="0dp">
            <ImageView
                android:id="@+id/iv_empty"
                android:layout_marginTop="@dimen/dp_76"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                android:src="@mipmap/home_ic_search_empty"
                android:layout_width="@dimen/dp_100"
                android:layout_height="@dimen/dp_100"/>
            <TextView
                android:id="@+id/tv_empty_tip"
                android:layout_marginTop="@dimen/dp_12"
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_FF999999"
                app:layout_constraintTop_toBottomOf="@id/iv_empty"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                android:text="Search no results, please search again~"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginStart="@dimen/dp_12"
                android:id="@+id/tv_empty_title"
                android:layout_marginTop="@dimen/dp_40"
                android:textSize="@dimen/sp_19"
                android:textColor="@color/c_333333"
                app:layout_constraintTop_toBottomOf="@id/tv_empty_tip"
                app:layout_constraintLeft_toLeftOf="parent"
                android:text="Popular recommendations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <View
                android:layout_width="@dimen/dp_0"
                android:layout_height="@dimen/dp_5"
                android:background="@drawable/shape_r3_9912c286"
                android:translationY="@dimen/dp_m_2"
                app:layout_constraintBottom_toBottomOf="@id/tv_empty_title"
                app:layout_constraintLeft_toLeftOf="@id/tv_empty_title"
                app:layout_constraintRight_toRightOf="@id/tv_empty_title" />
            <androidx.recyclerview.widget.RecyclerView
                android:layout_marginTop="@dimen/dp_12"
                app:layout_constraintTop_toBottomOf="@id/tv_empty_title"
                android:id="@+id/rv_recommend"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@id/btn_next"
                android:layout_marginBottom="@dimen/dp_24"
                />

            <com.china.travel.widget.widget.WeightTextView
                android:id="@+id/btn_next"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_56"
                android:layout_marginHorizontal="@dimen/dp_30"
                android:layout_marginBottom="@dimen/dp_10"
                android:background="@drawable/shape_r100_ff12c286"
                android:gravity="center"
                android:text="Tailor my trip"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_18"
                android:textFontWeight="600"
               app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>