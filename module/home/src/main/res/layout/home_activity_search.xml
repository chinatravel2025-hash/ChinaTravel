<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/color_bg_F3FFF8"
        android:layout_width="match_parent"  
        android:layout_height="match_parent">
        <ImageView
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <com.example.base.view.StatusBarHolderView
            android:id="@+id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_marginTop="@dimen/dp_10"
            android:id="@+id/ll_search"
            android:layout_marginHorizontal="@dimen/dp_12"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/shape_r8_fff"
            app:layout_constraintTop_toBottomOf="@id/view_holder"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50">
            <ImageView
                android:layout_marginStart="@dimen/dp_5"
                android:src="@mipmap/ic_home_search"
                android:layout_width="@dimen/dp_30"
                android:layout_height="@dimen/dp_30"/>

            <androidx.appcompat.widget.AppCompatEditText
                android:textCursorDrawable="@drawable/shape_cursor"
                android:id="@+id/ed_email"
                android:textSize="@dimen/sp_17"
                android:layout_marginStart="@dimen/dp_5"
                android:hint="@string/home_search_where_to"
                android:gravity="center_vertical"
                android:textColor="@color/c_333333"
                android:textColorHint="@color/text_FF999999"
                android:singleLine="true"
                android:background="@color/transparent"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_48"/>
            <ImageView
                android:layout_marginEnd="@dimen/dp_8"
                android:src="@mipmap/x_20_close"
                android:padding="@dimen/dp_8"
                android:layout_width="@dimen/dp_36"
                android:layout_height="@dimen/dp_36"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
           app:layout_constraintTop_toBottomOf="@id/ll_search"
            android:layout_marginTop="@dimen/dp_16"
            android:id="@+id/rv_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
        />



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>