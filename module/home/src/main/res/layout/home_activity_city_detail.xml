<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="vm"
            type="com.travel.home.vm.HomeCityDetailViewModel" />
        <variable
            name="type"
            type="com.aws.bean.entities.home.ObjectType" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_bg_F3FFF8">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <com.example.base.view.StatusBarHolderView
                android:id="@+id/view_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:padding="@dimen/dp_10"
                android:src="@mipmap/ic_black_top_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_holder" />

            <TextView
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{vm.mCityDetail.city_name}"
                android:textColor="@color/c_333333"
                android:textSize="@dimen/sp_24"
                app:layout_constraintBottom_toBottomOf="@id/iv_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_back" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_40"
            android:layout_marginTop="@dimen/dp_8"
            android:background="@color/white"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/cons_top" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nest_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_top">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:paddingBottom="@dimen/dp_30"
                android:paddingTop="@dimen/dp_16"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <FrameLayout
                    android:id="@+id/fl_banner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_215"
                    android:layout_marginHorizontal="@dimen/dp_12"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.youth.banner.Banner
                        android:transitionName="share_city"
                        android:id="@+id/banner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:banner_indicator_normal_color="@color/bg_FFD9D9D9"
                        app:banner_indicator_selected_color="@color/bg_7DAAB0"
                        app:layout_constraintTop_toTopOf="parent" />
                </FrameLayout>

                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    android:id="@+id/tv_city_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_17"
                    android:text="@{vm.mCityDetail.city_name}"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/fl_banner" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_city_name"
                    app:layout_constraintLeft_toLeftOf="@id/tv_city_name"
                    app:layout_constraintRight_toRightOf="@id/tv_city_name" />

                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    android:id="@+id/tv_about"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_5"
                    android:text="About"
                    android:textStyle="bold"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_15"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_city_name" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_marginTop="@dimen/dp_5"
                        android:layout_marginHorizontal="@dimen/dp_12"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_about"
                        android:id="@+id/rv_about_content"
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="wrap_content"/>

                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    android:id="@+id/tv_day_trip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_25"
                    android:text="Day Trips"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_about_content" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_day_trip"
                    app:layout_constraintLeft_toLeftOf="@id/tv_day_trip"
                    app:layout_constraintRight_toRightOf="@id/tv_day_trip" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_marginEnd="@dimen/dp_12"
                    android:onClick="@{()->vm.moreContent(type.TRAVEL_PRODUCTS)}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/tv_day_trip"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_day_trip">

                    <TextView
                        android:id="@+id/tv_a"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="@color/txt_12C286"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_1"
                        android:layout_marginTop="@dimen/dp_2"
                        android:background="@color/txt_12C286"
                        app:layout_constraintLeft_toLeftOf="@id/tv_a"
                        app:layout_constraintRight_toRightOf="@id/tv_a"
                        app:layout_constraintTop_toBottomOf="@id/tv_a" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_day_trip"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_180"
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintTop_toBottomOf="@id/tv_day_trip" />


                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    android:id="@+id/tv_sight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_22"
                    android:text="Sightseeing"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_day_trip" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_sight"
                    app:layout_constraintLeft_toLeftOf="@id/tv_sight"
                    app:layout_constraintRight_toRightOf="@id/tv_sight" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_marginEnd="@dimen/dp_12"
                    android:onClick="@{()->vm.moreContent(type.SIGHT)}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/tv_sight"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_sight">

                    <TextView
                        android:id="@+id/tv_b"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="@color/txt_12C286"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_1"
                        android:layout_marginTop="@dimen/dp_2"
                        android:background="@color/txt_12C286"
                        app:layout_constraintLeft_toLeftOf="@id/tv_b"
                        app:layout_constraintRight_toRightOf="@id/tv_b"
                        app:layout_constraintTop_toBottomOf="@id/tv_b" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sight"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_165"
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintTop_toBottomOf="@id/tv_sight" />


                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    android:id="@+id/tv_shop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_22"
                    android:text="Local shop"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_sight" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_shop"
                    app:layout_constraintLeft_toLeftOf="@id/tv_shop"
                    app:layout_constraintRight_toRightOf="@id/tv_shop" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_marginEnd="@dimen/dp_12"
                    android:onClick="@{()->vm.moreContent(type.SHOP)}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/tv_shop"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_shop">

                    <TextView
                        android:id="@+id/tv_c"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="@color/txt_12C286"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_1"
                        android:layout_marginTop="@dimen/dp_2"
                        android:background="@color/txt_12C286"
                        app:layout_constraintLeft_toLeftOf="@id/tv_c"
                        app:layout_constraintRight_toRightOf="@id/tv_c"
                        app:layout_constraintTop_toBottomOf="@id/tv_c" />
                </androidx.constraintlayout.widget.ConstraintLayout>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_shop"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_165"
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintTop_toBottomOf="@id/tv_shop" />

                <TextView
                    android:layout_marginStart="@dimen/dp_12"
                    android:id="@+id/tv_restaurant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_22"
                    android:text="Restaurant"
                    android:textColor="@color/c_333333"
                    android:textSize="@dimen/sp_19"
                    android:textStyle="bold"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rv_shop" />

                <View
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_5"
                    android:background="@drawable/shape_r3_9912c286"
                    android:translationY="@dimen/dp_m_2"
                    app:layout_constraintBottom_toBottomOf="@id/tv_restaurant"
                    app:layout_constraintLeft_toLeftOf="@id/tv_restaurant"
                    app:layout_constraintRight_toRightOf="@id/tv_restaurant" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_marginEnd="@dimen/dp_12"
                    android:onClick="@{()->vm.moreContent(type.RESTAURANT)}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/tv_restaurant"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_restaurant">

                    <TextView
                        android:id="@+id/tv_d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="@color/txt_12C286"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:layout_width="@dimen/dp_0"
                        android:layout_height="@dimen/dp_1"
                        android:layout_marginTop="@dimen/dp_2"
                        android:background="@color/txt_12C286"
                        app:layout_constraintLeft_toLeftOf="@id/tv_d"
                        app:layout_constraintRight_toRightOf="@id/tv_d"
                        app:layout_constraintTop_toBottomOf="@id/tv_d" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_restaurant"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_165"
                    android:layout_marginTop="@dimen/dp_12"
                    app:layout_constraintTop_toBottomOf="@id/tv_restaurant" />
                <TextView
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_56"
                    android:layout_marginHorizontal="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_24"
                    android:background="@drawable/shape_r100_ff12c286"
                    android:gravity="center"
                    android:text="Tailor my trip"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_18"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/rv_restaurant" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>