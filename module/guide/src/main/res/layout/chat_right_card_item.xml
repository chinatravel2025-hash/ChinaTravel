<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>


    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dp_16">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/dp_4"
                android:gravity="right"
                android:orientation="horizontal"
                android:padding="@dimen/dp_6">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp_140"
                    android:layout_weight="1"
                    android:background="@drawable/shape_radius_dp8_ffffff"
                    android:padding="@dimen/dp_8"
                    app:layout_constraintLeft_toRightOf="@+id/include_avatar"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_name">

                    <ImageView
                        android:id="@+id/iv_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="@dimen/dp_14"
                        android:adjustViewBounds="true"
                        android:background="@color/transparent"
                        android:scaleType="fitXY" />

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp_12"
                        android:layout_marginTop="@dimen/dp_12"
                        android:background="@color/bg_12C286"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxLength="15"
                        android:maxLines="1"
                        android:padding="@dimen/dp_2"
                        android:text="city walk"
                        android:textColor="@color/white"
                        android:textSize="@dimen/dp_14" />

                    <TextView
                        android:id="@+id/tv_about"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp_12"
                        android:layout_marginTop="@dimen/dp_38"
                        android:background="@color/bg_12C286"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxLength="15"
                        android:maxLines="1"
                        android:padding="@dimen/dp_2"
                        android:text="city walk"
                        android:textColor="@color/white"
                        android:textSize="@dimen/dp_14" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxLines="1"
                        android:text="China Travel"
                        android:textColor="@color/txt_FF666666"
                        android:textSize="@dimen/dp_10" />

                </FrameLayout>

                <include
                    android:id="@+id/include_avatar"
                    layout="@layout/chat_border_avatar"
                    android:layout_width="@dimen/dp_54"
                    android:layout_height="@dimen/dp_54"
                    android:adjustViewBounds="true" />

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</layout>