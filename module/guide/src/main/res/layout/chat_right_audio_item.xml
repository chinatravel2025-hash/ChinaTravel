<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>


    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_cb"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_8"
            android:adjustViewBounds="true"
            android:gravity="center"
            android:scaleType="fitXY"
            android:src="@mipmap/ic_msg_cb_un" />
        <FrameLayout
            android:gravity="right"
            android:layout_toEndOf="@+id/iv_cb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/dp_1"
            android:orientation="horizontal"
            android:padding="@dimen/dp_6">
            <ImageView
                android:id="@+id/iv_error"
                android:layout_gravity="center_vertical"
                app:layout_constraintRight_toLeftOf="@+id/ll_content"
                app:layout_constraintTop_toTopOf="@+id/ll_content"
                app:layout_constraintBottom_toBottomOf="@+id/ll_content"
                android:padding="@dimen/dp_8"
                android:layout_width="@dimen/dp_32"
                android:layout_height="@dimen/dp_32"
                android:src="@mipmap/ic_network_sigh"
                android:adjustViewBounds="true" />

            <org.libpag.PAGImageView
                android:id="@+id/lav_loading"
                android:layout_gravity="center_vertical"
                android:layout_width="@dimen/dp_32"
                android:layout_height="@dimen/dp_32"
                app:layout_constraintRight_toLeftOf="@+id/ll_content"
                app:layout_constraintTop_toTopOf="@+id/ll_content"
                app:layout_constraintBottom_toBottomOf="@+id/ll_content"
                android:layout_marginEnd="@dimen/dp_12"
                android:adjustViewBounds="true"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/ll_content"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_40"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/dp_4"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/include_avatar"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_spot"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="@dimen/dp_0"
                    android:background="@android:color/transparent"
                    android:outlineAmbientShadowColor="@android:color/transparent"
                    android:outlineSpotShadowColor="@android:color/transparent"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/dp_8"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false">

                    <FrameLayout
                        android:background="@color/read_dot_bg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:background="@mipmap/chat_img_pop_me_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_40"
                    android:layout_gravity="center_vertical"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/dp_15">

                    <TextView
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_vertical"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxWidth="@dimen/dp_200"
                        android:maxLines="1"
                        android:paddingStart="@dimen/dp_8"
                        android:paddingEnd="@dimen/dp_16"
                        android:textColor="@color/white"
                        android:textSize="@dimen/dp_12" />

                </LinearLayout>

            </LinearLayout>

            <include
                android:id="@+id/include_avatar"
                layout="@layout/chat_border_avatar"
                android:layout_width="@dimen/dp_54"
                android:layout_height="@dimen/dp_54"
                android:adjustViewBounds="true"
                android:background="@color/transparent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
    </RelativeLayout>
</layout>