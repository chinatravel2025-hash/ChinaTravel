<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.travel.guide.viewmodel.SingleChatViewModel" />

        <variable
            name="f"
            type="com.travel.guide.fragment.SingleChatFragment" />

    </data>

    <FrameLayout
        android:id="@+id/fl_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/dp_10"
            android:visibility="@{vm.isDoubleClickMode?View.GONE:View.VISIBLE}">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="@{vm.isVoiceType==2?View.VISIBLE:View.GONE}">

                <ImageView
                    android:src="@mipmap/img_pop_delete_voice"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_88"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="@dimen/dp_14"
                    android:adjustViewBounds="true"
                    android:visibility="@{vm.isTouchTopType?View.VISIBLE:View.GONE}" />

                <TextView
                    android:textColor="@color/black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:paddingBottom="@dimen/dp_12"
                    android:singleLine="true"
                    android:text="Swipe up to cancel | Release to send"
                    android:textSize="@dimen/dp_12" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!--      左边小头像                  -->
                        <FrameLayout
                            android:layout_width="@dimen/dp_48"
                            android:layout_height="@dimen/dp_48"
                            android:layout_marginStart="@dimen/dp_13"
                            android:adjustViewBounds="true"
                            android:onClick="@{()->f.onChangeVideo()}"
                            android:visibility="@{vm.isVoiceType==0&amp;&amp;vm.isChatType==0?View.VISIBLE:View.GONE}">

                            <com.makeramen.roundedimageview.RoundedImageView
                                android:id="@+id/iv_ower"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="@dimen/dp_2"
                                android:adjustViewBounds="true"
                                android:scaleType="centerCrop"
                                app:riv_oval="true" />

                        </FrameLayout>

                        <!--    长按的那个,包含语音条   -->
                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:visibility="@{vm.isVoiceType==0?View.GONE:View.VISIBLE}">

                            <com.example.base.weiget.LongTimerAndMoveButton
                                android:id="@+id/ltb"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dp_48"
                                android:layout_marginStart="@dimen/dp_68"
                                android:layout_marginEnd="@dimen/dp_13" />


                        </FrameLayout>

                        <!--    文本框                -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                           android:layout_marginHorizontal="@dimen/dp_14"
                            android:layout_weight="1"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:minHeight="@dimen/dp_48"
                            android:orientation="horizontal"
                            android:visibility="@{vm.isVoiceType==0?View.VISIBLE:View.GONE}">

                            <EditText
                                android:id="@+id/et_content"
                                android:background="@color/bg_gray_fff7f7f7"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:hint="Say something..."
                                android:imeOptions="actionSend"
                                android:inputType="textMultiLine"
                                android:letterSpacing="0.05"
                                android:lineSpacingExtra="4dp"
                                android:maxLines="7"
                                android:minHeight="@dimen/dp_48"
                                android:minLines="1"
                                android:paddingHorizontal="@dimen/dp_10"
                                android:paddingVertical="@dimen/dp_6"
                                android:textColor="@color/black"
                                android:textColorHighlight="@color/bg_EDF0F4"
                                android:textCursorDrawable="@null"
                                android:textSize="15sp" />


                            <TextView
                                android:id="@+id/tv_content"
                                android:background="@mipmap/img_btn_32_fill_default"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/dp_32"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="@dimen/dp_8"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:onClick="@{()->f.onSend()}"
                                android:paddingHorizontal="@dimen/dp_8"
                                android:singleLine="true"
                                android:text="Send"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:visibility="@{vm.isInputType?View.VISIBLE:View.GONE}" />

                        </LinearLayout>


                    </LinearLayout>

                    <!--          引用  -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp_71"
                        android:layout_marginTop="@dimen/dp_4"
                        android:layout_marginRight="@dimen/dp_74"
                        android:background="@drawable/shape_round_bg_12dp_f1f1f1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="@{vm.isQuote?View.VISIBLE:View.GONE}">

                        <TextView
                            android:id="@+id/tv_quote"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:minLines="1"
                            android:paddingHorizontal="@dimen/dp_10"
                            android:text="@{vm.quoteTxt}"
                            android:textColor="@color/bg_788094"
                            android:textSize="@dimen/dp_10" />

                        <ImageView
                            android:layout_width="@dimen/dp_20"
                            android:layout_height="@dimen/dp_20"
                            android:adjustViewBounds="true"
                            android:onClick="@{()->f.onCancelQuoteClick()}"
                            android:padding="@dimen/dp_2"
                            android:src="@mipmap/ic_edit_close" />

                    </LinearLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>
                <!--      长按的lottie 动画效果          -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_48"
                    android:layout_marginStart="@dimen/dp_10"
                    android:layout_marginEnd="@dimen/dp_13"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:visibility="@{vm.isVoiceType==2 &amp;&amp; !vm.isTouchTopType?View.VISIBLE:View.GONE}"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/dp_10"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:background="@color/red_f01164"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.airbnb.lottie.LottieAnimationView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_marginEnd="@dimen/dp_16"
                            android:adjustViewBounds="true"
                            app:lottie_autoPlay="true"
                            app:lottie_fileName="ct/im/volume_black.json"
                            app:lottie_loop="true" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_48"
                    android:layout_marginStart="@dimen/dp_10"
                    android:layout_marginEnd="@dimen/dp_13"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:visibility="@{vm.isVoiceType==2 &amp;&amp; vm.isTouchTopType?View.VISIBLE:View.GONE}"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/dp_10"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:background="@color/red_f01164"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.airbnb.lottie.LottieAnimationView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:layout_marginEnd="@dimen/dp_16"
                            android:adjustViewBounds="true"
                            app:lottie_autoPlay="true"
                            app:lottie_fileName="ct/im/volume_white.json"
                            app:lottie_loop="true" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </FrameLayout>


            <!--  底部四个按钮 相机，照骗，电话，表情          -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:paddingVertical="7dp"
                android:visibility="@{vm.isVoiceType==2?View.INVISIBLE:View.VISIBLE}">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp_40"
                    android:layout_weight="1"
                    android:onClick="@{()->f.onSendImg(0)}"
                    android:scaleType="centerInside"
                    android:src="@mipmap/ic_btn_ceamra" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="@dimen/dp_40"
                    android:layout_weight="1"
                    android:adjustViewBounds="true"

                    android:onClick="@{()->f.onSendImg(1)}"
                    android:scaleType="centerInside"
                    android:src="@mipmap/ic_btn_image" />

            </LinearLayout>

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_80"
            android:orientation="horizontal"
            android:visibility="@{vm.isDoubleClickMode?View.VISIBLE:View.GONE}">

            <View
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/bg_FFF5F5F5"
                />
            
            <FrameLayout
                android:id="@+id/fl_delete"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintWidth_percent="0.5" >


                <ImageView
                    android:src="@mipmap/img_28_icon_ashcan"
                    android:layout_width="@dimen/dp_38"
                    android:layout_height="@dimen/dp_38"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:onClick="@{()->f.onDeleteClick()}"
                    android:padding="5dp"
                  />

            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                app:layout_constraintLeft_toRightOf="@id/fl_delete"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintWidth_percent="0.5"
               >
                <ImageView
                    android:src="@mipmap/img_28_icon_forward"
                    android:layout_width="@dimen/dp_38"
                    android:layout_height="@dimen/dp_38"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:adjustViewBounds="true"
                    android:onClick="@{()->f.onRelayClick()}"
                    android:padding="5dp"
                   />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</layout>