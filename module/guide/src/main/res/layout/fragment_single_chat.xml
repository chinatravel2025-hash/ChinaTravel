<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:bind="http://schemas.android.com/tools"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.travel.guide.viewmodel.SingleChatViewModel" />

        <variable
            name="f"
            type="com.travel.guide.fragment.SingleChatFragment" />

        <import type="android.text.TextUtils" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.example.base.view.StatusBarHolderView
                android:id="@+id/sbh_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <RelativeLayout
                android:id="@+id/fl_root"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/fl_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <!--顶部按钮view容器-->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_top"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_44"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:id="@+id/icon_group"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="@{vm.isChatType==0?View.VISIBLE:View.GONE}"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/iv_more"
                                android:layout_width="@dimen/dp_40"
                                android:layout_height="@dimen/dp_40"
                                android:layout_gravity="right"
                                android:layout_marginEnd="@dimen/dp_4"
                                android:adjustViewBounds="true"
                                android:onClick="@{()->f.onSetting()}" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_back"
                            android:layout_width="@dimen/dp_40"
                            android:layout_height="@dimen/dp_40"
                            android:layout_marginStart="@dimen/dp_8"
                            android:adjustViewBounds="true"
                            android:src="@mipmap/ic_launcher"
                            android:visibility="@{vm.isChatType==0 &amp;&amp; !vm.isDoubleClickMode?View.VISIBLE:View.INVISIBLE}"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="@dimen/dp_44"
                            android:layout_height="@dimen/dp_44"
                            android:layout_marginStart="@dimen/dp_8"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:onClick="@{()->f.onCancelDoubleClick()}"
                            android:text="@string/cancel"
                            android:textColor="@color/black"
                            android:textSize="@dimen/dp_14"
                            android:visibility="@{!vm.isDoubleClickMode?View.GONE:View.VISIBLE}"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />


                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <com.example.base.weiget.NoAnimationRecyclerView
                        android:id="@+id/rv_list"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        app:layout_constraintTop_toBottomOf="@+id/cl_top"
                        app:layout_constraintBottom_toTopOf="@+id/view_bottom_chat"
                        android:requiresFadingEdge="none" />
                    <include
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:id="@+id/view_bottom_chat"
                        layout="@layout/include_single_chat_window"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_44"
                    android:layout_marginTop="@dimen/dp_44"
                    android:layout_marginStart="@dimen/dp_50"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:onClick="@{()->f.login1()}"
                    android:text="登录用户1"
                    android:textColor="@color/black"
                    android:textSize="@dimen/dp_14"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_44"
                    android:layout_marginTop="@dimen/dp_44"
                    android:layout_marginStart="@dimen/dp_200"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:onClick="@{()->f.login2()}"
                    android:text="登录用户2"
                    android:textColor="@color/black"
                    android:textSize="@dimen/dp_14"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </RelativeLayout>
        </LinearLayout>
    </FrameLayout>
</layout>