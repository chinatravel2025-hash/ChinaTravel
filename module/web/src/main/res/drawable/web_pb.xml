<layer-list xmlns:android="http://schemas.android.com/apk/res/android" >

    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="2dp" />
            <gradient
                android:angle="270"
                android:centerColor="@color/ui_bg_F0"
                android:endColor="@color/ui_bg_F0"
                android:startColor="@color/ui_bg_F0" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="2dp" />
                <gradient
                    android:centerColor="@color/liji_c_blue"
                    android:endColor="@color/liji_c_blue"
                    android:startColor="@color/liji_c_blue" />

            </shape>
        </clip>
    </item>

</layer-list>