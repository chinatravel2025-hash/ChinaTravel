<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>



        <import type="android.view.View" />
    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:background="@color/color_bg_F3FFF8">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@mipmap/home_top_bg"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <com.example.base.view.StatusBarHolderView
                android:id="@+id/view_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:padding="@dimen/dp_10"
                android:src="@mipmap/ic_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_holder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Map Itinerary"
                android:textStyle="bold"
                android:textColor="@color/c_333333"
                android:textSize="@dimen/sp_24"
                app:layout_constraintBottom_toBottomOf="@id/iv_back"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_back" />
        </androidx.constraintlayout.widget.ConstraintLayout>


        <com.amap.api.maps2d.MapView
            app:layout_constraintTop_toBottomOf="@id/cons_top"
            android:layout_marginTop="@dimen/dp_12"
            android:id="@+id/map_view"
            android:layout_width="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="0dp"/>
       <View
           android:visibility="gone"
           app:layout_constraintBottom_toBottomOf="parent"
           android:background="@drawable/map_bottom"
           android:layout_width="match_parent"
           android:layout_height="@dimen/dp_200"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_day"
            android:visibility="gone"
            app:layout_constraintRight_toRightOf="parent"
           app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginBottom="@dimen/dp_6"
            app:layout_constraintBottom_toTopOf="@id/view_pager"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_40"/>

        <androidx.viewpager.widget.ViewPager
            android:visibility="gone"
            android:layout_marginHorizontal="@dimen/dp_36"
            android:id="@+id/view_pager"
            android:clipChildren="false"
            android:layout_marginBottom="@dimen/dp_20"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_110"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>