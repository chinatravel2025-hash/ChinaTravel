<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/shape_main_dialog_bg"
        android:layout_marginHorizontal="@dimen/dp_14"
        android:paddingBottom="@dimen/dp_35"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_marginHorizontal="@dimen/dp_6"
            android:layout_marginTop="@dimen/dp_2"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@mipmap/status_dialog_top_bg"
            android:adjustViewBounds="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/iv_status"
            android:layout_marginTop="@dimen/dp_25"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@mipmap/status_dialog_right_tag"
            android:layout_width="@dimen/dp_98"
            android:layout_height="@dimen/dp_98"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_content"
            android:layout_marginTop="@dimen/dp_14"
            app:layout_constraintTop_toBottomOf="@id/iv_status"
            tools:text="The new password \n has been set successfully"
           android:gravity="center"
            android:textStyle="bold"
            android:layout_marginHorizontal="@dimen/dp_40"
            android:textSize="@dimen/sp_20"
            android:textColor="@color/c_333333"
            android:lineHeight="@dimen/dp_25"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:textColor="@color/white"
            android:textSize="@dimen/sp_18"
            android:textStyle="bold"
            android:text="Back to travel"
            android:gravity="center"
            android:layout_marginHorizontal="@dimen/dp_18"
            android:layout_marginTop="@dimen/dp_25"
            android:background="@drawable/shape_main_btn_ff12c286"
            app:layout_constraintTop_toBottomOf="@id/tv_content"
            android:id="@+id/btn_text"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_56"/>




    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>