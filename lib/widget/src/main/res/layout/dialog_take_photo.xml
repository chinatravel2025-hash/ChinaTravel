<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:ignore="MissingDefaultResource">
    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/dp_20"
   >
    <TextView
        android:id="@+id/tv_take_phone"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/dp_32"
        android:gravity="center|top"
        android:text="Take a photo"
        android:textColor="@color/c_333333"
        android:textSize="@dimen/sp_16"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_46"/>
    <View
        android:id="@+id/line"
        app:layout_constraintTop_toBottomOf="@id/tv_take_phone"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:background="@color/line_FFE9E9E9"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_0_5"/>
    <TextView
        android:id="@+id/select_album"
        app:layout_constraintTop_toBottomOf="@id/line"
        android:gravity="center|bottom"
        android:text="Select from album"
        android:textColor="@color/c_333333"
        android:textSize="@dimen/sp_16"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_46"/>
    <View
        android:layout_marginTop="@dimen/dp_20"
        android:id="@+id/line_bottom"
        app:layout_constraintTop_toBottomOf="@id/select_album"
        android:background="@color/bg_F6F6F6"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_4"/>
    <TextView
        android:id="@+id/tv_cancel"
        app:layout_constraintTop_toBottomOf="@id/line_bottom"
        android:gravity="center"
        android:text="Cancel"
        android:paddingVertical="@dimen/dp_16"
        android:textColor="@color/c_333333"
        android:textSize="@dimen/sp_16"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</androidx.constraintlayout.widget.ConstraintLayout>

    </layout>