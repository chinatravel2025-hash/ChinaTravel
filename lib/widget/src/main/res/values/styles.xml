<resources xmlns:tools="http://schemas.android.com/tools">



    <!--Dialog弹出弹出和取消动画效果-->
    <style name="ui_dialog_animation">
        <item name="android:windowEnterAnimation">@anim/dialog_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_out</item>
    </style>
    <style name="ui_bottom_in_out_anim">
        <item name="android:windowEnterAnimation">@anim/bottom_in</item>
        <item name="android:windowExitAnimation">@anim/bottom_out</item>
    </style>

    <!--Dialog弹窗样式-->
    <style name="ui_style_dialog" parent="@android:style/Theme.Dialog">
      <!--  <item name="android:windowBackground">@android:color/transparent</item>--><!--背景透明-->
        <item name="android:windowAnimationStyle">@style/ui_dialog_animation</item>
        <item name="android:windowFrame">@null</item><!--边框-->
        <item name="android:windowIsFloating">true</item><!--是否浮现在activity之上-->
        <item name="android:windowIsTranslucent">true</item><!--半透明-->
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item><!--模糊-->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!--Dialog弹窗样式,从下面弹出-->
    <style name="ui_style_dialog_bottom" parent="ui_style_dialog">
        <item name="android:windowAnimationStyle">@style/ui_bottom_in_out_anim</item>
    </style>


    <style name="ui_style_dialog_center" parent="@android:style/Theme.Dialog" tools:ignore="ResourceName">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:background">@android:color/transparent</item>
    </style>


    <style name="BottomSheetDialogTheme" parent="BaseBottomSheetDialog">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
    </style>


    <style name="BaseBottomSheetDialog" parent="@style/Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheet</item>
    </style>

    <style name="BottomSheet" parent="@style/Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/white_rounded_dialog</item>
    </style>


    <style name="TabLayoutTextStyle" parent="TextAppearance.Design.Tab">
        <item name="textAllCaps">false</item>
    </style>

</resources>